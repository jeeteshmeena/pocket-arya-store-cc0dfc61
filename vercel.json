{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": false,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/(.*)", "dest": "http://158.101.4.188/api/$1" },
    { "src": "/aryaPremium(.*)", "dest": "/index.html" },
    { "src": "/terms",    "dest": "/terms.html" },
    { "src": "/privacy",  "dest": "/privacy.html" },
    { "src": "/refund",   "dest": "/refund.html" },
    { "src": "/shipping", "dest": "/shipping.html" },
    { "src": "/contact",  "dest": "/contact.html" },
    { "handle": "filesystem" },
    { "src": "/",         "dest": "/landing.html" }
  ]
}
