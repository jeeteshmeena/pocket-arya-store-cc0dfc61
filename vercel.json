{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://158.101.4.188/api/:path*" },
    { "source": "/aryaPremium/:path*", "destination": "/aryaPremium/index.html" },
    { "source": "/aryaPremium",  "destination": "/aryaPremium/index.html" },
    { "source": "/terms",    "destination": "/terms.html" },
    { "source": "/privacy",  "destination": "/privacy.html" },
    { "source": "/refund",   "destination": "/refund.html" },
    { "source": "/shipping", "destination": "/shipping.html" },
    { "source": "/contact",  "destination": "/contact.html" },
    { "source": "/",         "destination": "/landing.html" }
  ]
}
